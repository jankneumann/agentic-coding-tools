{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "AGENT_ID=\"${AGENT_ID:-codex-1}\" AGENT_TYPE=\"${AGENT_TYPE:-codex}\" COORDINATION_API_URL=\"${COORDINATION_API_URL:-http://localhost:8081}\" COORDINATION_API_KEY=\"${COORDINATION_API_KEY:-}\" python3 agent-coordinator/scripts/print_coordinator_env.py"
      },
      {
        "type": "command",
        "command": "AGENT_ID=\"${AGENT_ID:-codex-1}\" AGENT_TYPE=\"${AGENT_TYPE:-codex}\" COORDINATION_API_URL=\"${COORDINATION_API_URL:-http://localhost:8081}\" COORDINATION_API_KEY=\"${COORDINATION_API_KEY:-}\" python3 agent-coordinator/scripts/register_agent.py"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "AGENT_ID=\"${AGENT_ID:-codex-1}\" AGENT_TYPE=\"${AGENT_TYPE:-codex}\" COORDINATION_API_URL=\"${COORDINATION_API_URL:-http://localhost:8081}\" COORDINATION_API_KEY=\"${COORDINATION_API_KEY:-}\" python3 agent-coordinator/scripts/report_status.py"
      }
    ]
  }
}
