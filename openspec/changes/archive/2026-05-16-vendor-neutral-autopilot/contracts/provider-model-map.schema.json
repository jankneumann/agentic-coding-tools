{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-coding-tools.dev/contracts/provider-model-map.schema.json",
  "title": "ProviderModelMap",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "providers", "tiers"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "tiers": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": ["premium", "standard", "economy"]
      },
      "uniqueItems": true
    },
    "providers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["premium", "standard", "economy"],
        "properties": {
          "premium": { "type": "string", "minLength": 1 },
          "standard": { "type": "string", "minLength": 1 },
          "economy": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
