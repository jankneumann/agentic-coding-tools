---
title: Transport Model and Graceful Degradation
---
graph TB
    subgraph CLI["CLI Agents (Local)"]
        CC["Claude Code"]
        CX["Codex CLI"]
        GM["Gemini CLI"]
    end

    subgraph CLOUD["Cloud Agents (Remote)"]
        CW["Claude Web"]
        CXC["Codex Cloud"]
    end

    CLI --> MCP["MCP Server\n(stdio transport)"]
    CLOUD --> HTTP["HTTP API\n(FastAPI + API-key)"]

    MCP --> COORD["Agent Coordinator\nPostgreSQL Backend"]
    HTTP --> COORD

    COORD --> CHECK{"check_coordinator.py\n--json"}

    CHECK -->|"all caps"| FULL["Parallel Skills\n(full coordination)"]
    CHECK -->|"some caps"| PARTIAL["Partial Coordination\n(selective features)"]
    CHECK -->|"unavailable"| NONE["Linear Fallback\n(single-agent mode)"]

    style CLI fill:#e8f5e9,stroke:#4CAF50,stroke-width:2px
