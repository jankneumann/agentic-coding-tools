#!/bin/sh
#
# Post-merge hook
#
# When a merge touches openspec/changes/<id>/tasks.md, invoke the coordinator
# task-status renderer to refresh that file's managed block from coordinator
# state. Renderer failures are non-blocking (just warn).
#
# Renderer-path resolution (see contracts/README.md "Hook Contract"):
#   1. $COORDINATOR_TASK_STATUS_RENDERER (test seam / emergency override)
#   2. <repo-root>/skills/coordinator-task-status-renderer/scripts/render_tasks_status.py

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Compare ORIG_HEAD..HEAD; if ORIG_HEAD is missing (rare), no-op.
if ! git rev-parse -q --verify ORIG_HEAD >/dev/null; then
    exit 0
fi

CHANGED=$(git diff --name-only ORIG_HEAD HEAD \
    | grep -E '^openspec/changes/[^/]+/tasks\.md$' || true)
if [ -z "$CHANGED" ]; then
    exit 0
fi

RENDERER="${COORDINATOR_TASK_STATUS_RENDERER:-$REPO_ROOT/skills/coordinator-task-status-renderer/scripts/render_tasks_status.py}"
if [ ! -e "$RENDERER" ]; then
    echo "[post-merge] renderer not found at $RENDERER; skipping tasks.md refresh" >&2
    exit 0
fi

case "$RENDERER" in
    *.py)
        PYTHON_BIN=""
        for candidate in \
            "$REPO_ROOT/skills/.venv/bin/python" \
            "$REPO_ROOT/agent-coordinator/.venv/bin/python"; do
            if [ -x "$candidate" ]; then
                PYTHON_BIN="$candidate"
                break
            fi
        done
        if [ -z "$PYTHON_BIN" ] && command -v python3 >/dev/null 2>&1; then
            PYTHON_BIN="python3"
        fi
        RENDER_CMD="$PYTHON_BIN $RENDERER"
        ;;
    *)
        RENDER_CMD="$RENDERER"
        ;;
esac

echo "$CHANGED" | while IFS= read -r path; do
    [ -z "$path" ] && continue
    change_id=$(echo "$path" | sed -E 's|^openspec/changes/([^/]+)/tasks\.md$|\1|')
    if [ -z "$change_id" ] || [ "$change_id" = "$path" ]; then
        continue
    fi
    # shellcheck disable=SC2086
    $RENDER_CMD "$change_id"
    RC=$?
    if [ $RC -ne 0 ]; then
        echo "[post-merge] renderer failed for $change_id (exit=$RC)" >&2
    fi
done

exit 0
