#!/bin/sh
#
# Pre-commit hook (chained)
#
# Chain order:
#   1. pre-commit.old (home-path leak detection)
#   2. ruff import sorting (auto-fix staged Python files)
#   (beads sync removed — issues now tracked in coordinator)

# --- 1. Run existing hook first ---
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -x "$HOOK_DIR/pre-commit.old" ]; then
    "$HOOK_DIR/pre-commit.old" "$@"
    EXIT_CODE=$?
    if [ $EXIT_CODE -ne 0 ]; then
        exit $EXIT_CODE
    fi
fi

# --- 2. Auto-fix ruff import sorting on staged Python files ---
# Find staged .py files (Added, Copied, Modified, Renamed)
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACMR -- '*.py')
if [ -n "$STAGED_PY" ]; then
    # Try ruff from known venv locations, then PATH
    RUFF=""
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    for candidate in \
        "$REPO_ROOT/agent-coordinator/.venv/bin/ruff" \
        "$REPO_ROOT/skills/.venv/bin/ruff"; do
        if [ -x "$candidate" ]; then
            RUFF="$candidate"
            break
        fi
    done
    if [ -z "$RUFF" ] && command -v ruff >/dev/null 2>&1; then
        RUFF="ruff"
    fi

    if [ -n "$RUFF" ]; then
        # Auto-fix import sorting in-place, then re-stage
        echo "$STAGED_PY" | xargs "$RUFF" check --select I --fix --quiet 2>/dev/null
        echo "$STAGED_PY" | xargs git add 2>/dev/null
    fi
fi

exit 0
